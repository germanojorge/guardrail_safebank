# ──────────────────────────────────────────────────────────────
# Guardrail SafeBank — Environment Example
#
#   cp .env.example .env
#   # Edite ML_CACHE_ROOT e os segredos abaixo
#
# ⚠️  Este arquivo É versionado. NUNCA coloque segredos reais aqui.
#     Coloque-os no `.env` (gitignored).
#
# Para variáveis shell-level (UV_CACHE_DIR, build do Docker):
#   set -a; source .env; set +a
#   uv run ...
#   docker compose up -d
#
# Para scripts Python / pytest: env_bootstrap carrega .env automaticamente.
# ──────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════
# Cache (núcleo do SCRUM-19)
# ═══════════════════════════════════════════════════════════════

ML_CACHE_ROOT="/run/media/germano/Novo volume/Linux/ml-cache"

# As variáveis abaixo são DERIVADAS automaticamente pelo guardrails/env_bootstrap.py
# a partir de ML_CACHE_ROOT.  Descomente apenas se quiser sobrescrever.
# HF_HOME="${ML_CACHE_ROOT}/huggingface"
# HF_DATASETS_CACHE="${ML_CACHE_ROOT}/huggingface/datasets"
# HF_HUB_CACHE="${ML_CACHE_ROOT}/huggingface/hub"
# TRANSFORMERS_CACHE="${ML_CACHE_ROOT}/huggingface/transformers"
# TMPDIR="${ML_CACHE_ROOT}/tmp"

# ═══════════════════════════════════════════════════════════════
# Shell-level (Python NÃO controla — precisa `source` antes de uv/docker)
# ═══════════════════════════════════════════════════════════════

UV_CACHE_DIR="${ML_CACHE_ROOT}/uv-cache"

# Comentário: estas variáveis só valem se você fizer
#   set -a; source .env; set +a
# antes de `uv run` ou `docker compose`, pois são lidas pelo binário uv
# e pelo daemon Docker, não pelo processo Python.

# ═══════════════════════════════════════════════════════════════
# Segredos (preenche no .env local — NUNCA aqui)
# ═══════════════════════════════════════════════════════════════

ANTHROPIC_API_KEY="sk-ant-..."
HF_TOKEN="hf_..."

# HF_TOKEN é necessário para repositórios gated (ex: Necent, Prompt-Guard-2).
# Pode ser gerado em: https://huggingface.co/settings/tokens

# ═══════════════════════════════════════════════════════════════
# Runtime (usados no docker-compose.yml e pela aplicação)
# ═══════════════════════════════════════════════════════════════

QDRANT_HOST="localhost"
QDRANT_COLLECTION="itau_faq"
LLM_PROVIDER="anthropic"
HF_HUB_OFFLINE="0"
TRANSFORMERS_OFFLINE="0"
