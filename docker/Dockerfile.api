# Use a pre-built models image to avoid re-downloading ~1.5GB of HF weights on every build.
# Build the models image separately:
#   docker build -f docker/Dockerfile.models -t llm-guardrails-tutorial-models:latest .
ARG MODELS_IMAGE=llm-guardrails-tutorial-models:latest
FROM ${MODELS_IMAGE} AS model-download

FROM python:3.12-slim
WORKDIR /app
COPY --from=model-download /root/.cache /root/.cache
COPY pyproject.toml uv.lock ./
COPY guardrails/ guardrails/
RUN pip install uv && uv sync --no-dev --frozen
EXPOSE 8000
CMD ["uv", "run", "guardrails-api"]
